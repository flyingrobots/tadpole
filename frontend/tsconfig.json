{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true,
    "noImplicitAny": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "svelte"]
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "vite-env.d.ts",
    "svelte-env.d.ts"
  ]
}
